# CROO Agent Protocol (CAP) configuration
# Copy to .env.d/croo.env and fill in values from https://agent.croo.network

CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_...

# Provider: map CROO listing UUIDs to Ligis service names.
# Find the UUID in the CROO Dashboard service listing URL.
# CROO sends the listing UUID as service_id in negotiation events;
# the provider uses these to map back to ligis.risk / ligis.verify / ligis.issue.
CROO_SERVICE_ID_LIGIS_RISK=<uuid from CROO dashboard>
CROO_SERVICE_ID_LIGIS_VERIFY=<uuid from CROO dashboard>
CROO_SERVICE_ID_LIGIS_ISSUE=<uuid from CROO dashboard>

# Requester: service to hire (legacy, used by demo scripts)
CROO_TARGET_SERVICE_ID=ligis.risk

# Demo script: counterparty subject (account-hash-... or DID)
# CROO_DEMO_SUBJECT=account-hash-...

# Ligis chain to use for on-chain verification/issuance (reads .env.d/casper.env when casper)
LIGIS_CHAIN=casper

# Provider: health endpoint port (defaults to 9430)
# LIGIS_CROO_HEALTH_PORT=9430

# Provider: idempotency DB path (defaults to ~/.ligis/croo-idempotency.db)
# LIGIS_CROO_IDEMPOTENCY_DB=/path/to/db

# Required only for the ligis.issue service
LIGIS_ISSUER_PRIVATE_KEY=...
