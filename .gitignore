# dependencies
/lib/
node_modules/
/packages/*/dist/
/packages/*/node_modules/
out/
cache/
broadcast/

# package build outputs
dist/

# typescript incremental build cache
*.tsbuildinfo

# secrets — never commit these
.env
.env.local
.env.*.local
.env.d/
*.key
*.pem
*.p12
*.pfx
*.secret
secrets/
deployments/localhost/

# deployment records (contain live addresses + deployer info)
.deployment-latest.json

# editor
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# test artifacts
coverage/
coverage.json
lcov.info
gas-report.txt

# foundry debug
debug.log
.trace

# npm
.npm
.npmrc

# claude code / commandcode / agent session-local config
.claude/
.commandcode/
.junie/
.agents/
.casper/

# video project — source tracked, rendered output + captures ignored
/video/*/ligis-demo.mp4
/video/*/renders/
/video/*/thumbs/
/video/*/assets/images/
/video/*/assets/audio/
/video/*/assets/captures/
/video/*/node_modules/
/video/*/package-lock.json

# accidental build output of an earlier tsc run — not the real package
# (real one is packages/adapter-casper/); keep ignored unless user confirms
/CredentialRegistry/

# Stray TypeScript emit outside dist/ (e.g. from an accidental global tsc run)
/packages/*/src/**/*.js
/packages/*/src/**/*.js.map
/packages/*/src/**/*.d.ts
/packages/*/test/**/*.js
/packages/*/test/**/*.js.map
/packages/*/test/**/*.d.ts
/scripts/*.js
/scripts/*.js.map
/scripts/*.d.ts
/web/app/**/*.js
/web/app/**/*.js.map
/web/app/**/*.d.ts
/web/components/**/*.js
/web/components/**/*.js.map
/web/components/**/*.d.ts
/web/lib/**/*.js
/web/lib/**/*.js.map
/web/lib/**/*.d.ts
