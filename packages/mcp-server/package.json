{
  "name": "@ligis/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Ligis — agent identity + capability credentials across chains",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ligis/adapter-0g": "workspace:*",
    "@ligis/adapter-casper": "workspace:*",
    "@ligis/adapter-evm": "workspace:*",
    "@ligis/agent-logic": "workspace:*",
    "@ligis/core": "workspace:*",
    "@ligis/zerog": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
