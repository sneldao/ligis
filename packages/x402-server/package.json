{
  "name": "@ligis/x402-server",
  "version": "0.1.0",
  "description": "Ligis Trust Gate — credential-gated x402 resource server on Casper",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@casper-ecosystem/casper-eip-712": "^1.2.0",
    "@hono/node-server": "^2.0.5",
    "@ligis/adapter-casper": "workspace:*",
    "@ligis/core": "workspace:*",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
